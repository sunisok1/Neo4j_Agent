# Local Neo4j (docker-compose)
LOCAL_NEO4J_URI=bolt://localhost:7687
LOCAL_NEO4J_USERNAME=neo4j
LOCAL_NEO4J_PASSWORD=local-neo4j-password
LOCAL_NEO4J_DATABASE=neo4j
LOCAL_NEO4J_HTTP_PORT=7474
LOCAL_NEO4J_BOLT_PORT=7687

# Remote Neo4j Aura
REMOTE_NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
REMOTE_NEO4J_USERNAME=neo4j
REMOTE_NEO4J_PASSWORD=your-aura-password
REMOTE_NEO4J_DATABASE=neo4j
